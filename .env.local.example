# Copy to .env.local and add your key. Without it, the app falls back to scripted demo AI output.
OPENAI_API_KEY=sk-...
# Optional overrides
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_TRANSCRIBE_MODEL=whisper-1

# AssemblyAI — used for the automated "Call" + voice transcription when set (preferred over Whisper)
ASSEMBLYAI_API_KEY=
ASSEMBLYAI_MODEL=universal

# Optional 2nd provider ("runaware") — image/vision enhancement seam
SECONDARY_AI_KEY=
